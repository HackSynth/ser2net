FROM centos:7

ARG GENSIO_VERSION=v2.8.4

RUN sed -i 's|mirrorlist=|#mirrorlist=|g' /etc/yum.repos.d/CentOS-*.repo && \
    sed -i 's|#baseurl=http://mirror.centos.org|baseurl=http://vault.centos.org|g' /etc/yum.repos.d/CentOS-*.repo && \
    sed -i 's|#baseurl=http://vault.centos.org/7|baseurl=http://vault.centos.org/7.9.2009|g' /etc/yum.repos.d/CentOS-*.repo

RUN yum install -y autoconf automake libtool gcc make && \
    yum install -y git && \
    yum install -y libyaml-devel && \
    yum install -y libev-devel libmd-devel libcurl-devel && \
    yum clean all

RUN cd /tmp && \
    git clone --depth 1 --branch ${GENSIO_VERSION} https://github.com/cminyard/gensio.git && \
    cd gensio && \
    ./autogen.sh && \
    ./configure --prefix=/usr/local && \
    make -j$(nproc) && \
    make install && \
    ldconfig && \
    rm -rf /tmp/gensio

WORKDIR /root/485/ser2net

COPY . .

RUN export PKG_CONFIG_PATH=/usr/local/lib/pkgconfig:$PKG_CONFIG_PATH && \
    ./autogen.sh && \
    ./configure --prefix=/usr/local && \
    make -j$(nproc)

ENTRYPOINT ["/bin/bash"]
